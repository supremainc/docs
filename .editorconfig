root = true

[*]
charset = utf-8
insert_final_newline = true

[*.{js,ts,tsx,jsx,json,css,scss,less,html}]
indent_style = space
indent_size = 2
end_of_line = lf

[*.{md,mdx}]
indent_style = space
indent_size = 2
end_of_line = lf
trim_trailing_whitespace = false

[*.{sh,bash}]
end_of_line = lf

[*.{bat,cmd,ps1}]
end_of_line = crlf
